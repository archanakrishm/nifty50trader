# ─── Broker API Keys ──────────────────────────────────────────────────────────
# Zerodha Kite Connect
ZERODHA_API_KEY=your_zerodha_api_key
ZERODHA_API_SECRET=your_zerodha_api_secret
ZERODHA_ACCESS_TOKEN=your_zerodha_access_token
ZERODHA_USER_ID=your_zerodha_user_id

# Angel One SmartAPI
ANGEL_API_KEY=your_angel_api_key
ANGEL_CLIENT_ID=your_angel_client_id
ANGEL_PASSWORD=your_angel_password
ANGEL_TOTP_SECRET=your_totp_secret

# Groww
GROWW_APP_ID=your_groww_app_id
GROWW_APP_SECRET=your_groww_app_secret

# ─── Claude AI ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ─── Application Settings ────────────────────────────────────────────────────
LOG_LEVEL=INFO
